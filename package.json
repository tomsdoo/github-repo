{
  "name": "@tomsd/github-repo",
  "version": "2.7.0",
  "type": "module",
  "description": "Utility for GitHub repo",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "make:typedoc": "sh buildTypedoc.sh",
    "lint": "biome check",
    "prepare": "husky",
    "serve:doc": "mdbook --serve --directory docs/",
    "test": "vitest"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npm run lint"
    ],
    "__test__/**/*.ts": [
      "npm run lint"
    ]
  },
  "keywords": [],
  "author": "tom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomsdoo/github-repo.git"
  },
  "bugs": {
    "url": "https://github.com/tomsdoo/github-repo/issues"
  },
  "homepage": "https://github.com/tomsdoo/github-repo#readme",
  "dependencies": {
    "@octokit/graphql": "9.0.3",
    "@octokit/rest": "22.0.1",
    "js-yaml": "5.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@octokit/openapi-types": "27.0.0",
    "@tomsd/md-book": "2.1.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.1.1",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "tsdown": "0.22.12",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
